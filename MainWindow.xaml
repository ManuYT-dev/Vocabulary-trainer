<Window x:Class="Vokabeltrainer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vokabeltrainer"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800"
        ResizeMode="NoResize"
        Loaded="Window_Loaded">
    <Canvas x:Name="Canvas_Main">
        <Grid Width="800" Height="30">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Column="0">
                <Label Content="Output:" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
                <ComboBox x:Name="ComboBox_Ausgabe" Width="120" Margin="10 5 20 5" SelectionChanged="ComboBox_SelectionChanged" SelectedIndex="0">
                    <ComboBoxItem Content="DE"></ComboBoxItem>
                    <ComboBoxItem Content="EN"></ComboBoxItem>
                    <ComboBoxItem Content="FR"></ComboBoxItem>
                </ComboBox>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Column="1">
                <Label Content="Input:" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"></Label>
                <ComboBox x:Name="ComboBox_Eingabe" Width="120" Margin="10 5 20 5" SelectionChanged="ComboBox_SelectionChanged" SelectedIndex="1">
                    <ComboBoxItem Content="DE"></ComboBoxItem>
                    <ComboBoxItem Content="EN"></ComboBoxItem>
                    <ComboBoxItem Content="FR"></ComboBoxItem>
                </ComboBox>
            </StackPanel>
            <Button x:Name="Button_Nächste" Content="Next" Grid.Column="2" Margin="20 5 20 5" Click="Button_Nächste_Click"/>
            <Button x:Name="Button_Verwalten" Content="Manage vocabs" Grid.Column="3" Margin="20 5 20 5" Click="Button_Verwalten_Click"></Button>
        </Grid>

        <Canvas x:Name="Canvas_Text" Width="300" Height="50" Canvas.Left="215" Canvas.Top="152">
        </Canvas>
        <ProgressBar x:Name="progressBar" Height="300" Canvas.Left="10" Canvas.Top="70" Width="20" Orientation="Vertical"/>
        <Button Content="Check" Canvas.Left="646" Canvas.Top="83" Height="321" Width="129" Click="Button_Click"/>
        <Label Content="Answer" Canvas.Left="60" Canvas.Top="207"/>
        <TextBox x:Name="textBox" Canvas.Left="118" TextWrapping="Wrap" Canvas.Top="207" Width="494" Height="28" HorizontalAlignment="Left" VerticalAlignment="Center"/>
    </Canvas>
</Window>
