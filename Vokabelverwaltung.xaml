<Window x:Class="Vokabeltrainer.Vokabelverwaltung"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vokabeltrainer"
        mc:Ignorable="d"
        Title="Vokabelverwaltung" Height="475" Width="800"
        Closing="Window_Closing"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        >
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition  Height="Auto"/>
            <RowDefinition  Height="Auto"/>
            <RowDefinition  Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DataGrid_MainGrid" d:ItemsSource="{d:SampleData ItemCount=5}" Height="350" VerticalAlignment="Top" Grid.Row="0"/>
        <StackPanel Grid.Row="2" Height="50" Margin="0 20 0 0" Orientation="Horizontal">
            <Button x:Name="Button_Add_Vocab" Content="Add Vocab" Width="175" Height="50" Margin="20 0 0 0" Background="Lime" FontWeight="Bold" FontSize="24" Click="Button_Add_Vocab_Click"></Button>
            <Button x:Name="Button_Remove_Vocab" Content="Remove Vocab" Width="175" Height="50" Margin="20 0 0 0" Background="Red" FontWeight="Bold" FontSize="24" Click="Button_Remove_Vocab_Click"></Button>
            <Button x:Name="Button_Load" Content="Save Vocabs" Width="175" Height="50" Margin="20 0 0 0" Background="#FF00C0FF" FontWeight="Bold" FontSize="24" Click="Button_Save_Click"></Button>
            <Button x:Name="Button_Save" Content="Load Vocabs" Width="175" Height="50" Margin="20 0 0 0" Background="#FF0061FF" FontWeight="Bold" FontSize="24" Click="Button_Load_Click"></Button>
        </StackPanel>
    </Grid>
</Window>
